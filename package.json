{
  "name": "servicewale",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for ServiceWale backend, customer web, customer app, serviceman mobile/web and admin panel.",
  "workspaces": [
    "backend",
    "customer-web",
    "customer-app",
    "serviceman-app",
    "serviceman-web",
    "admin-panel"
  ],
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "scripts": {
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend start",
    "backend:seed:admin": "npm --prefix backend run seed:admin",
    "customer-web:dev": "npm --prefix customer-web run dev",
    "customer-web:build": "npm --prefix customer-web run build",
    "customer-app:start": "npm --prefix customer-app start",
    "serviceman-app:start": "npm --prefix serviceman-app start",
    "serviceman-app:android": "npm --prefix serviceman-app run android",
    "serviceman-web:dev": "npm --prefix serviceman-web run dev",
    "serviceman-web:build": "npm --prefix serviceman-web run build",
    "admin-panel:dev": "npm --prefix admin-panel run dev"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tslib": "^2.8.1"
  }
}
